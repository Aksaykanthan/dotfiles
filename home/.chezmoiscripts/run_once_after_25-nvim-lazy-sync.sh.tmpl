{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# LazyVim starter is cloned by .chezmoiexternal.yaml; do the first headless
# plugin sync here so `nvim` isn't slow/interactive the first time it's run.
set -euo pipefail

if command -v nvim >/dev/null 2>&1 && [ -d "$HOME/.config/nvim" ]; then
  echo "==> nvim: headless Lazy sync"
  nvim --headless "+Lazy! sync" +qa >/dev/null 2>&1 || true
fi
{{ end -}}
