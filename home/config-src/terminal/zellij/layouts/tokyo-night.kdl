// Custom layout: replaces zellij's built-in tab-bar + status-bar with a
// single zjstatus (https://github.com/dj95/zjstatus) bar - powerline-style
// segments in the Tokyo Night palette shared with Ghostty/fish/oh-my-posh.
// zjstatus is a third-party WASM plugin fetched (and cached) by zellij on
// first launch of this layout - pinned to a specific release for
// reproducibility instead of "latest".
//
// pane_frames is disabled globally in config.kdl per zjstatus's own
// guidance, and hide_frame_for_single_pane below re-enables frames only
// once a tab has more than one pane, so single-pane tabs stay chrome-free.

layout {
    default_tab_template {
        children
        pane size=2 borderless=true {
            plugin location="https://github.com/dj95/zjstatus/releases/download/v0.24.0/zjstatus.wasm" {
                // Tokyo Night color aliases - referenced below as $name.
                color_bg     "#1a1b26"
                color_fg     "#c0caf5"
                color_muted  "#565f89"
                color_blue   "#7aa2f7"
                color_green  "#9ece6a"
                color_yellow "#e0af68"
                color_purple "#bb9af7"
                color_red    "#f7768e"
                color_cyan   "#7dcfff"

                format_left   "{mode}#[fg=$blue,bg=$bg] #[fg=$bg,bg=$blue,bold]  {session} #[fg=$blue,bg=$bg]"
                format_center "{tabs}"
                format_right  "{command_git_branch}#[fg=$muted,bg=$bg]{datetime}"
                format_space  "#[bg=$bg]"

                format_hide_on_overlength "true"
                format_precedence         "clr"

                hide_frame_for_single_pane "true"

                border_enabled  "true"
                border_char     "─"
                border_format   "#[fg=$muted]{char}"
                border_position "top"

                // Mode indicator: bold color-blocked pill, one color per
                // zellij mode so the active keybinding context is obvious
                // at a glance.
                mode_normal          "#[fg=$bg,bg=$blue,bold]  NORMAL "
                mode_locked          "#[fg=$bg,bg=$red,bold]  LOCKED "
                mode_pane            "#[fg=$bg,bg=$green,bold]  PANE "
                mode_tab             "#[fg=$bg,bg=$purple,bold]  TAB "
                mode_resize          "#[fg=$bg,bg=$yellow,bold]  RESIZE "
                mode_move            "#[fg=$bg,bg=$cyan,bold]  MOVE "
                mode_scroll          "#[fg=$bg,bg=$yellow,bold]  SCROLL "
                mode_search          "#[fg=$bg,bg=$yellow,bold]  SEARCH "
                mode_enter_search    "#[fg=$bg,bg=$yellow,bold]  SEARCH "
                mode_rename_tab      "#[fg=$bg,bg=$purple,bold]  RENAME "
                mode_rename_pane     "#[fg=$bg,bg=$green,bold]  RENAME "
                mode_session         "#[fg=$bg,bg=$blue,bold]  SESSION "
                mode_prompt          "#[fg=$bg,bg=$yellow,bold]  PROMPT "
                mode_default_to_mode "normal"

                // Tabs: numbered pill for the active tab, muted plain text
                // for the rest - keeps a busy session scannable.
                tab_normal              "#[fg=$muted,bg=$bg]  {index} {name} "
                tab_normal_fullscreen   "#[fg=$muted,bg=$bg]  {index} {name} [] "
                tab_normal_sync         "#[fg=$muted,bg=$bg]  {index} {name} <> "
                tab_active              "#[fg=$bg,bg=$blue,bold]  {index} {name} "
                tab_active_fullscreen   "#[fg=$bg,bg=$blue,bold]  {index} {name} [] "
                tab_active_sync         "#[fg=$bg,bg=$blue,bold]  {index} {name} <> "
                tab_separator           "#[fg=$bg,bg=$bg] "
                tab_rename              "#[fg=$bg,bg=$yellow,bold]  {index} {name} "

                // Right side: current git branch (if any) and the clock.
                command_git_branch_command    "git rev-parse --abbrev-ref HEAD"
                command_git_branch_format     "#[fg=$yellow,bg=$bg]  {stdout} "
                command_git_branch_interval   "5"
                command_git_branch_rendermode "static"

                datetime        "#[fg=$muted,bg=$bg]  {format} "
                datetime_format "%H:%M"
            }
        }
    }
}
