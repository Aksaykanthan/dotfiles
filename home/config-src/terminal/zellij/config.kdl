// Zellij terminal multiplexer. Theme matches Ghostty's "TokyoNight Night"
// for a cohesive look between the terminal and the multiplexer inside it.

theme "tokyo-night-dark"
default_layout "compact"
default_shell "fish"

// Rounded pane borders + no first-run noise.
show_startup_tips false
show_release_notes false

ui {
    pane_frames {
        rounded_corners true
    }
}
