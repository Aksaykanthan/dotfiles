// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "ssh_connections": [
    {
      "host": "asai11",
      "args": [],
      "projects": [
        {
          "paths": ["/home/evalify/evalify"],
        },
      ],
    },
  ],
  "icon_theme": "Light Charmed Icons",
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
    "hide_root": true,
    "auto_fold_dirs": false,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "left",
  },
  "disable_ai": true,
  "session": {
    "trust_all_worktrees": true,
  },
  "format_on_save": "on",
  "autosave": "on_focus_change",
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "gemini-3.1-pro-preview",
    },
    "model_parameters": [],
  },
  "prettier": {
    "allowed": true,
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Panda",
  },
  "status_bar": {
    "experimental.show": false,
  },
  "tab_bar": {
    "show_tab_bar_buttons": false,
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": false,
    "runnables": false,
  },
  "indent_guides": {
    "enabled": false,
  },
  "vim_mode": true,
}
